@startuml component

skinparam monochrome false
skinparam componentStyle rectangle
skinparam backgroundColor #191A1C
skinparam defaultFontName "Malgun Gothic"

skinparam defaultFontColor #E0E0E0
skinparam arrowColor #7EC8E3
skinparam arrowFontColor #E0E0E0

skinparam package {
    BackgroundColor #252628
    BorderColor #555555
    FontColor #E0E0E0
}

skinparam component {
    BackgroundColor #2E3033
    BorderColor #666666
    FontColor #E0E0E0
}

skinparam database {
    BackgroundColor #2E3033
    BorderColor #666666
    FontColor #E0E0E0
}

skinparam cloud {
    BackgroundColor #2E3033
    BorderColor #666666
    FontColor #E0E0E0
}

skinparam rectangle {
    BackgroundColor #2E3033
    BorderColor #666666
    FontColor #E0E0E0
}

skinparam title {
    FontColor #E0E0E0
}

title 돌의 정령 챗봇 - 컴포넌트 다이어그램

package "Client" {
    [Unity\nSpiritChat.cs] as Unity
    [Gradio\napp.py] as Gradio
}

package "Server" {
    [FastAPI\nserver.py] as ApiServer
}

package "Core" {
    [NPC_manager.py\nRAG + Pydantic 검증] as NPC
    [agent_manager.py\nLangGraph ReAct] as Agent
    [crawler.py\n나무위키 크롤링] as Crawler
    [api_manager.py\nOpenAI Embedding] as API
}

database "ChromaDB\nVector DB" as DB
cloud "OpenAI\nGPT-5.4-mini" as GPT
[namu.wiki] as Wiki

Unity  -->  ApiServer : HTTP POST /chat
Gradio -->  NPC       : 직접 호출
ApiServer -->  NPC

NPC    -->  DB
NPC    -->  GPT
Agent  -->  GPT
Crawler --> Wiki   : 크롤링
Crawler --> DB     : 저장
Crawler --> API
API    --> GPT

@enduml
